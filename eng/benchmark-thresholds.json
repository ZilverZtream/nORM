{
  "schemaVersion": 1,
  "description": "v1 RC benchmark budgets. Ratios compare the target method to the fastest available baseline method for the same provider.",
  "rules": [
    {
      "name": "Simple runtime stays within Dapper or optimized Raw ADO range",
      "provider": "*",
      "targetMethods": [ "Query_Simple_nORM" ],
      "baselineMethods": [ "Query_Simple_Dapper", "Query_Simple_RawAdo_Optimized" ],
      "maxMeanRatio": 1.5,
      "maxAllocatedRatio": 3.0,
      "required": true
    },
    {
      "name": "Simple compiled stays within prepared Raw ADO range",
      "provider": "*",
      "targetMethods": [ "Query_Simple_nORM_Compiled" ],
      "baselineMethods": [ "Query_Simple_RawAdo_PreparedOptimized", "Query_Simple_Dapper" ],
      "maxMeanRatio": 1.35,
      "maxAllocatedRatio": 3.0,
      "required": true
    },
    {
      "name": "Complex runtime stays within Dapper or optimized Raw ADO range",
      "provider": "*",
      "targetMethods": [ "Query_Complex_nORM" ],
      "baselineMethods": [ "Query_Complex_Dapper", "Query_Complex_RawAdo_Optimized" ],
      "maxMeanRatio": 1.6,
      "maxAllocatedRatio": 3.0,
      "required": true
    },
    {
      "name": "Complex compiled stays within prepared Raw ADO range",
      "provider": "*",
      "targetMethods": [ "Query_Complex_nORM_Compiled" ],
      "baselineMethods": [ "Query_Complex_RawAdo_PreparedOptimized", "Query_Complex_Dapper" ],
      "maxMeanRatio": 1.4,
      "maxAllocatedRatio": 3.0,
      "required": true
    },
    {
      "name": "Compiled join stays competitive with typed Dapper and optimized Raw ADO",
      "provider": "*",
      "targetMethods": [ "Query_Join_nORM_Compiled" ],
      "baselineMethods": [ "Query_Join_Dapper", "Query_Join_RawAdo_Optimized" ],
      "maxMeanRatio": 1.25,
      "maxAllocatedRatio": 3.0,
      "required": true
    },
    {
      "name": "Batched insert stays within EF or Dapper range",
      "provider": "*",
      "targetMethods": [ "BulkInsert_Batched_nORM", "BulkInsert_Batched_nORM_Prepared" ],
      "baselineMethods": [ "BulkInsert_Batched_EfCore", "BulkInsert_Batched_Dapper" ],
      "maxMeanRatio": 1.5,
      "maxAllocatedRatio": 3.0,
      "required": true
    }
  ]
}
