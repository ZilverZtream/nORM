## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# NuGet
*.nupkg
*.snupkg
.nuget/

# IDE
.vs/
.vscode/
.idea/
.dotnet-home/

# OS
.DS_Store
Thumbs.db

# BenchmarkDotNet output
/BenchmarkDotNet.Artifacts/
/benchmarks/BenchmarkDotNet.Artifacts/
/artifacts/

# Coverage and test result artifacts
tests/TestResults/
*.trx
*.coverage
coverage/
coverage-report/

# Local ad-hoc PowerShell scratch files only. Release and engineering scripts
# under eng/ or .github/ must remain visible to git.
*.local.ps1
*.scratch.ps1
.claude/
.tmp/

# Playwright MCP session artifacts (local only)
.playwright-mcp/
